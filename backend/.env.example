# SF TENNIS KIDS Club Environment Variables
# Copy this file to .env and fill in your values

# Gmail credentials for sending emails
# You need to create an App Password in your Google Account
# Instructions: https://support.google.com/accounts/answer/185833
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-16-char-app-password

# Optional: Change default port
# PORT=5000

# Optional: Disable debug mode in production
# FLASK_DEBUG=0
